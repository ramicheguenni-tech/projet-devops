{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"color": "red","value": null},{"color": "green","value": 1}]},
          "mappings": [{"options": {"0": {"text": "DOWN"},"1": {"text": "UP"}},"type": "value"}]
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background","reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "up{job=\"devops-app\"}","legendFormat": "Status"}],
      "title": "App Status",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"},"unit": "s","thresholds": {"steps": [{"color": "green","value": null}]}}},
      "gridPos": {"h": 4, "w": 5, "x": 4, "y": 0},
      "id": 2,
      "options": {"colorMode": "background","reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "process_uptime_seconds{job=\"devops-app\"}","legendFormat": "Uptime"}],
      "title": "Uptime (seconds)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"},"unit": "bytes","thresholds": {"steps": [{"color": "green","value": null},{"color": "yellow","value": 200000000},{"color": "red","value": 350000000}]}}},
      "gridPos": {"h": 4, "w": 5, "x": 9, "y": 0},
      "id": 3,
      "options": {"colorMode": "background","reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "sum(jvm_memory_used_bytes{job=\"devops-app\", area=\"heap\"})","legendFormat": "Heap"}],
      "title": "JVM Heap Used",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"},"unit": "percentunit","thresholds": {"steps": [{"color": "green","value": null},{"color": "yellow","value": 0.5},{"color": "red","value": 0.8}]}}},
      "gridPos": {"h": 4, "w": 5, "x": 14, "y": 0},
      "id": 4,
      "options": {"colorMode": "background","reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "process_cpu_usage{job=\"devops-app\"}","legendFormat": "CPU"}],
      "title": "CPU Usage",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"},"thresholds": {"steps": [{"color": "green","value": null}]}}},
      "gridPos": {"h": 4, "w": 5, "x": 19, "y": 0},
      "id": 5,
      "options": {"colorMode": "background","reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "sum(http_server_requests_seconds_count{job=\"devops-app\"})","legendFormat": "Requests"}],
      "title": "Total HTTP Requests",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"},"unit": "bytes"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 6,
      "options": {"tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "sum(jvm_memory_used_bytes{job=\"devops-app\", area=\"heap\"})","legendFormat": "Heap Used"},
        {"expr": "sum(jvm_memory_committed_bytes{job=\"devops-app\", area=\"heap\"})","legendFormat": "Heap Committed"},
        {"expr": "sum(jvm_memory_max_bytes{job=\"devops-app\", area=\"heap\"})","legendFormat": "Heap Max"},
        {"expr": "sum(jvm_memory_used_bytes{job=\"devops-app\", area=\"nonheap\"})","legendFormat": "Non-Heap Used"}
      ],
      "title": "JVM Memory Over Time",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"},"unit": "reqps"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 7,
      "options": {"tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "sum by (uri, method, status) (rate(http_server_requests_seconds_count{job=\"devops-app\"}[1m]))","legendFormat": "{{method}} {{uri}} [{{status}}]"}
      ],
      "title": "HTTP Request Rate by Endpoint",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"},"unit": "s"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "id": 8,
      "targets": [
        {"expr": "sum by (uri) (rate(http_server_requests_seconds_sum{job=\"devops-app\"}[1m])) / sum by (uri) (rate(http_server_requests_seconds_count{job=\"devops-app\"}[1m]))","legendFormat": "Avg {{uri}}"}
      ],
      "title": "Response Time Average",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "id": 9,
      "targets": [
        {"expr": "jvm_threads_live_threads{job=\"devops-app\"}","legendFormat": "Live"},
        {"expr": "jvm_threads_daemon_threads{job=\"devops-app\"}","legendFormat": "Daemon"},
        {"expr": "jvm_threads_peak_threads{job=\"devops-app\"}","legendFormat": "Peak"}
      ],
      "title": "JVM Threads",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"},"unit": "percentunit"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "id": 10,
      "targets": [
        {"expr": "process_cpu_usage{job=\"devops-app\"}","legendFormat": "Process CPU"},
        {"expr": "system_cpu_usage{job=\"devops-app\"}","legendFormat": "System CPU"}
      ],
      "title": "CPU Usage Over Time",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "id": 11,
      "targets": [
        {"expr": "jvm_gc_pause_seconds_count{job=\"devops-app\"}","legendFormat": "GC Count {{action}}"},
        {"expr": "jvm_gc_pause_seconds_sum{job=\"devops-app\"}","legendFormat": "GC Time {{action}}"}
      ],
      "title": "Garbage Collection",
      "type": "timeseries"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["devops","spring","sesame","rami"],
  "time": {"from": "now-1h","to": "now"},
